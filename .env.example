# SEO Blog Post Creation Tool - Configuration Template
# Copy this file to .env and fill in your actual keys

# Google Gemini API Key (Required for AI features)
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# WordPress Configuration (Optional for Auto-Publishing)
WORDPRESS_URL=https://your-site.com
WORDPRESS_USER=your_username
WORDPRESS_PASSWORD=your_app_password

# Medium Configuration (Optional)
MEDIUM_TOKEN=your_medium_integration_token
